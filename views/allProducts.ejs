<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>
<body>
     <div class="container py-4">
         <div class="d-flex justify-content-between align-items-center mb-3">
             <h1 class="h3 mb-0">All Products</h1>
         </div>

         <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
             <% allProducts.forEach(product => { %>
                 <div class="col d-flex">
                     <div class="card w-100">
                         <img class="card-img-top" src="<%= product.product_image %>" alt="<%= product.product_name %>" style="object-fit: cover; height: 180px;">
                         <div class="card-body d-flex flex-column">
                             <h5 class="card-title"><%= product.product_name %></h5>
                             <p class="card-text flex-grow-1"><%= product.product_desc %></p>

                             <div class="d-flex justify-content-between align-items-center mb-2">
                                 <span class="fw-semibold">$<%= product.product_price %></span>
                                 <small class="text-body-secondary">Qty: <%= product.product_quantity %></small>
                             </div>

                             <div class="d-flex gap-2">
                                 <a href="/admin/edit-product/<%= product._id %>" class="btn btn-outline-primary btn-sm">
                                    Edit
                                 </a>
                                 <form action="/admin/delete/<%= product._id %>" method="post">
                                    <button class="btn btn-outline-danger btn-sm">Delete</button>
                                 </form>
                             </div>
                         </div>
                     </div>
                 </div>
             <% }) %>
         </div>
     </div>
</body>
</html>